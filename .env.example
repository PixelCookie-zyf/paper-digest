# LLM API (any OpenAI-compatible endpoint)
# Works with: MiniMax, OpenAI, DeepSeek, Qwen, Ollama, vLLM, etc.
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.minimaxi.com/v1
LLM_MODEL=MiniMax-M2.7

# Examples for other providers:
# LLM_BASE_URL=https://api.openai.com/v1          LLM_MODEL=gpt-4o
# LLM_BASE_URL=https://api.deepseek.com/v1        LLM_MODEL=deepseek-chat
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1  LLM_MODEL=qwen-max
# LLM_BASE_URL=http://localhost:11434/v1           LLM_MODEL=llama3    (Ollama)

# Output
OUTPUT_DIR=output
